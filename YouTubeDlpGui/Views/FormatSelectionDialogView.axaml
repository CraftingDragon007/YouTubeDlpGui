<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:YouTubeDlpGui.ViewModels"
        x:Class="YouTubeDlpGui.Views.FormatSelectionDialogView"
        x:DataType="vm:FormatSelectionDialogViewModel"
        Title="Select yt-dlp Format"
        Width="900"
        Height="600"
        MinWidth="700"
        MinHeight="450"
        Padding="20">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Available formats" FontSize="18" FontWeight="Bold" />
            <TextBlock Text="Select a row to use its format id, or type any yt-dlp -f selector such as bestvideo+bestaudio, 137+140, or best[height&lt;=1080]." TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <TextBlock Text="Format selector passed to -f" />
            <TextBox Text="{Binding FormatSelector}" Margin="0,4,0,12" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Use Format" Command="{Binding UseFormatCommand}" Margin="0,0,10,0" />
                <Button Content="Clear Custom Format" Command="{Binding ClearCommand}" Margin="0,0,10,0" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
            </StackPanel>
        </StackPanel>

        <Border BorderBrush="Gray" BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ListBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:YtDlpFormatOption">
                            <TextBlock Text="{Binding Details}" FontFamily="Consolas, Menlo, monospace" TextWrapping="NoWrap" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
