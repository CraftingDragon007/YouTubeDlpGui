<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:YouTubeDlpGui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
        x:Class="YouTubeDlpGui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="YouTubeDlpGui"
        SizeToContent="Height"
        Width="500"
        CanResize="False"
        Padding="20"
        TransparencyLevelHint="AcrylicBlur">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.red">
            <Setter Property="Foreground" Value="Red" />
        </Style>
    </Window.Styles>

    <StackPanel>
        <TextBlock Name="ErrorTextBlock" Classes="red" IsVisible="False" TextWrapping="WrapWithOverflow" />
        <TextBlock>YouTube Video URL</TextBlock>
        <TextBox Margin="10" Name="UrlTextBox" PlaceholderText="https://www.youtube.com/watch?v=dQw4w9WgXcQ" />
        <WrapPanel>
            <TextBox Margin="10" Name="VideoDownloadPathTextBox" MinWidth="300" />
            <Button Margin="10" Name="VideoDownloadPathButton" Content="..."
                    Command="{Binding OnVideoDownloadPathButtonClicked}" HorizontalAlignment="Right" />
        </WrapPanel>
        <WrapPanel Margin="10,0,10,10">
            <CheckBox Name="UseSystemYtDlpCheckBox" Content="Use system yt-dlp" Margin="0,0,16,0" />
            <CheckBox Name="UseSystemFfmpegCheckBox" Content="Use system ffmpeg" />
        </WrapPanel>
        <WrapPanel Margin="10,0,10,10">
            <CheckBox Name="RedownloadYtDlpCheckBox" Content="Redownload yt-dlp" Margin="0,0,16,0" />
            <CheckBox Name="RedownloadFfmpegCheckBox" Content="Redownload ffmpeg" />
        </WrapPanel>
        <WrapPanel>
            <StackPanel Margin="10">
                <TextBlock>Video</TextBlock>
                <TextBlock>Format:</TextBlock>
            </StackPanel>
            <ComboBox Name="FinalFormatComboBox" Margin="10" SelectedIndex="0" MinWidth="90">
                <ComboBoxItem>mp4</ComboBoxItem>
                <ComboBoxItem>webm</ComboBoxItem>
                <ComboBoxItem>mkv</ComboBoxItem>
                <ComboBoxItem>flv</ComboBoxItem>
                <ComboBoxItem>avi</ComboBoxItem>
                <ComboBoxItem>wmv</ComboBoxItem>
                <ComboBoxItem>mov</ComboBoxItem>
                <ComboBoxItem>3gp</ComboBoxItem>
                <ComboBoxItem>3g2</ComboBoxItem>
                <ComboBoxItem>mp3</ComboBoxItem>
                <ComboBoxItem>aac</ComboBoxItem>
                <ComboBoxItem>wav</ComboBoxItem>
                <ComboBoxItem>ogg</ComboBoxItem>
                <ComboBoxItem>flac</ComboBoxItem>
            </ComboBox>
            <StackPanel Margin="10">
                <TextBlock>Formatting</TextBlock>
                <TextBlock>Method:</TextBlock>
            </StackPanel>
            <ComboBox Name="FormattingMethodComboBox" Margin="10" SelectedIndex="0" MinWidth="140">
                <ComboBoxItem>Auto</ComboBoxItem>
                <ComboBoxItem>Remux</ComboBoxItem>
                <ComboBoxItem>Re-Encode</ComboBoxItem>
            </ComboBox>

        </WrapPanel>
        <TextBlock Name="ProcessingInfoTextBlock" Margin="10,0,10,10" Text="Auto will remux when possible and re-encode only when needed." TextWrapping="Wrap" />
        <WrapPanel>
            <StackPanel Margin="10">
                <TextBlock>Video</TextBlock>
                <TextBlock>Encoding:</TextBlock>
            </StackPanel>
            <ComboBox Name="VideoEncodingComboBox" Margin="10" SelectedIndex="0" MinWidth="120">
                <ComboBoxItem>Auto</ComboBoxItem>
                <ComboBoxItem>libx264</ComboBoxItem>
                <ComboBoxItem>libx265</ComboBoxItem>
                <ComboBoxItem>libsvtav1</ComboBoxItem>
                <ComboBoxItem>librav1e</ComboBoxItem>
                <ComboBoxItem>libaom-av1</ComboBoxItem>
                <ComboBoxItem>libvpx-vp9</ComboBoxItem>
                <ComboBoxItem>mpeg4</ComboBoxItem>
                <ComboBoxItem>flv</ComboBoxItem>
            </ComboBox>
            <StackPanel Margin="10">
                <TextBlock>Audio</TextBlock>
                <TextBlock>Encoding:</TextBlock>
            </StackPanel>
            <ComboBox Name="AudioEncodingComboBox" Margin="10" SelectedIndex="0" MinWidth="120">
                <ComboBoxItem>Auto</ComboBoxItem>
                <ComboBoxItem>aac</ComboBoxItem>
                <ComboBoxItem>libopus</ComboBoxItem>
                <ComboBoxItem>libmp3lame</ComboBoxItem>
                <ComboBoxItem>flac</ComboBoxItem>
                <ComboBoxItem>pcm_s16le</ComboBoxItem>
                <ComboBoxItem>libvorbis</ComboBoxItem>
            </ComboBox>
        </WrapPanel>
        <TextBlock Margin="10,0,10,10" Text="Selecting a video or audio encoding is only used when the output is re-encoded. Choose Auto to let the target container decide compatible defaults." TextWrapping="Wrap" />
        <WrapPanel>
            <StackPanel Margin="10">
                <TextBlock>Detailed</TextBlock>
                <TextBlock>Format:</TextBlock>
            </StackPanel>
            <TextBox Margin="10" Name="SelectedDetailedFormatTextBox" MinWidth="260" IsReadOnly="True" Text="{Binding SelectedDetailedFormatText}" />
            <Button Margin="10" Name="FormatSelectionButton" Content="Select..." Command="{Binding OnSelectFormatButtonClicked}" />
        </WrapPanel>
        <Button Margin="10" Name="DownloadButton" IsEnabled="True" Content="Download" HorizontalAlignment="Center"
                VerticalAlignment="Center" Command="{Binding OnDownloadButtonClicked}" />
        <TextBlock Name="StatusLabel">Ready</TextBlock>
        <Grid Margin="10" ColumnDefinitions="55,24,120,48,82,35,*">
            <TextBlock Grid.Column="0" Name="CurrentDownloadPercentageTextBlock" TextAlignment="Right">0%</TextBlock>
            <TextBlock Grid.Column="1" Name="DownloadOfTextBlock" Margin="8,0,0,0">of</TextBlock>
            <TextBlock Grid.Column="2" Name="DownloadSizeTextBlock" Margin="8,0,0,0">0MiB</TextBlock>
            <TextBlock Grid.Column="3" Name="DownloadAtTextBlock" Margin="8,0,0,0">at</TextBlock>
            <TextBlock Grid.Column="4" Name="DownloadSpeedTextBlock" Margin="8,0,0,0">0 KiB/s</TextBlock>
            <TextBlock Grid.Column="5" Name="DownloadEtaTextBlock" Margin="8,0,0,0">ETA</TextBlock>
            <TextBlock Grid.Column="6" Name="RemainingTimeTextBlock" Margin="8,0,0,0">00:00</TextBlock>
        </Grid>
        <ProgressBar Name="CurrentDownloadProgressBar" Value="0" />
    </StackPanel>

</Window>
