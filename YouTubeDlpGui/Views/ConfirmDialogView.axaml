<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:YouTubeDlpGui.ViewModels"
        x:Class="YouTubeDlpGui.Views.ConfirmDialogView"
        x:DataType="vm:ConfirmDialogViewModel"
        Title="Confirm"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        Padding="20">
    <StackPanel>
        <TextBlock Text="{Binding Message}" Margin="0,0,0,20"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Yes" Command="{Binding YesCommand}" Margin="0,0,10,0"/>
            <Button Content="No" Command="{Binding NoCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>
